# ── PostgreSQL ──────────────────────────────
# Эти значения Postgres использует при создании БД,
# и из них же собирается DATABASE_URL ниже.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=smart_tracker

# Хост=postgres (имя сервиса), порт=5432 — адрес ВНУТРИ docker-сети.
# Собирается из переменных выше, менять креды нужно только в них.
DATABASE_URL="postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}"

# ── Безопасность ────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── SMTP (почта) ────────────────────────────
# Для разработки — Mailtrap Sandbox. Креды берутся из Sandbox → Integration.
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@smart-tracker.local